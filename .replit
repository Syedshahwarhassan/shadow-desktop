modules = ["python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["espeak-ng", "freetype", "glibcLocales", "gobject-introspection", "gtk3", "lcms2", "libayatana-appindicator", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "portaudio", "scrot", "tcl", "tk", "xvfb-run", "zlib"]
